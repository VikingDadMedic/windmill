{
  "workspace_id": "starter",
  "name": "mongodb_rest",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "endpoint": {
        "type": "string",
        "description": "For example: https://data.mongodb-api.com/app/<APP_ID>/endpoint/data/v1",
        "default": ""
      },
      "api_key": {
        "type": "string",
        "description": "",
        "default": ""
      }
    },
    "required": [
      "endpoint",
      "api_key"
    ],
    "type": "object"
  },
  "description": "Resource type to access MongoDB through the Atlas Data API"
}
