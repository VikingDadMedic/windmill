{
  "workspace_id": "starter",
  "name": "linkding",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "token": {
        "type": "string",
        "description": "API token to connect to the API",
        "default": ""
      },
      "baseUrl": {
        "type": "string",
        "description": "The baseUrl of the instance",
        "default": ""
      }
    },
    "required": [
      "token"
    ],
    "type": "object"
  },
  "description": "https://github.com/sissbruecker/linkding/blob/master/README.md"
}
